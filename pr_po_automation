output_dir = '/content/gdrive/Shareddrives/Gojek FP&A Central Drive/81. Others/automation/streamlining_region&salestracker/output/'
consolidated_file_path = os.path.join(output_dir, 'consolidated.xlsx')

# Process and save individual files
for file_name in os.listdir(input_dir):
    if file_name.upper().endswith('.XLSX'):
        file_path = os.path.join(input_dir, file_name)
        rns_sheets = process_prelim_file(file_path)
        output_file_path = os.path.join(output_dir, f'processed_{file_name.lower()}')

        with pd.ExcelWriter(output_file_path, engine='openpyxl') as writer:
            if rns_sheets:
                for rns_name, df_rns in rns_sheets.items():
                    df_rns.to_excel(writer, sheet_name=rns_name, index=False)
            else:
                pd.DataFrame({'No Data': ['No matching RNS Mapping found']}).to_excel(writer, sheet_name='Empty', index=False)

# Consolidate sheets
consolidated_sheets = {}
for file_name in os.listdir(output_dir):
    if file_name.startswith('processed_') and file_name.endswith('.xlsx'):
        file_path = os.path.join(output_dir, file_name)
        xls = pd.ExcelFile(file_path)
        for sheet_name in xls.sheet_names:
            if sheet_name != 'Empty':  # Skip empty sheets
                df = pd.read_excel(xls, sheet_name=sheet_name)
                # Optional: enforce end-before-mapping order here too
                # df = _reorder_cols_end_before_mapping(df)
                if sheet_name in consolidated_sheets:
                    consolidated_sheets[sheet_name] = pd.concat([consolidated_sheets[sheet_name], df], ignore_index=True)
                else:
                    consolidated_sheets[sheet_name] = df

# Save consolidated data
with pd.ExcelWriter(consolidated_file_path, engine='openpyxl') as writer:
    for sheet_name, df in consolidated_sheets.items():
        df.to_excel(writer, sheet_name=sheet_name, index=False)

print(f"Consolidated file saved as: {consolidated_file_path}")
